AUTH_TRUST_HOST=1
AUTH_SECRET=GENERATE_WITH: npx auth secret
NEXTAUTH_URL=https://itassetregister.yourdomain.local

AUTH_MICROSOFT_ENTRA_ID_ID=your-azure-app-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-azure-app-client-secret
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0

AUTH_DOMAIN=@yourdomain.ie
AUTH_ALT_DOMAIN=@youralternatedomain.ie

# BASE_INPUT_URL can also point to a local file if the server isn't running:
#   file:///C:/ITAssetRegister/server/openapi.json
# (save the spec from /api/docs/json while server is running, then reference it here)
BASE_INPUT_URL=http://localhost:3333/api/docs/json
BASE_URL=http://localhost:3333
